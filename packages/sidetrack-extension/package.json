{
  "name": "@sidetrack/extension",
  "description": "Sidetrack Chrome MV3 extension for local AI-work tracking.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && npm run e2e:prepare-companion && npm run e2e:verify && npm run e2e:playwright",
    "e2e:playwright": "playwright test",
    "e2e:prepare-companion": "npm --prefix ../sidetrack-companion run build",
    "e2e:verify": "node scripts/verify-extension-build.mjs",
    "e2e:login": "npm run build && node scripts/login-test-profile.mjs",
    "e2e:chrome-debug": "npm run build && node scripts/chrome-debug.mjs",
    "e2e:install-cft": "node scripts/install-cft.mjs",
    "e2e:gc-cft": "node scripts/gc-cft.mjs",
    "e2e:pair": "node scripts/pair-extension.mjs",
    "e2e:codex-inbound": "node scripts/codex-inbound-e2e.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^9.39.1",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  }
}
