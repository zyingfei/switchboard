{
  "name": "@sidetrack/companion",
  "description": "Local Sidetrack companion process for loopback API and vault writes.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "sidetrack-companion": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@iarna/toml": "^2.2.5",
    "@wlearn/lightgbm": "^0.1.0",
    "gpt-tokenizer": "^3.4.0",
    "graphology": "^0.26.0",
    "hnswlib-node": "^3.0.0",
    "minisearch": "^7.2.0",
    "sqlite-vec": "^0.1.9",
    "usearch": "2.25.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "bunx --bun --no-install tsc -p tsconfig.build.json",
    "typecheck": "bunx --bun --no-install tsc --noEmit -p tsconfig.json",
    "lint": "bunx --bun --no-install eslint \"**/*.{ts,tsx}\"",
    "format": "bunx --bun --no-install prettier --write .",
    "format:check": "bunx --bun --no-install prettier --check .",
    "lint:openapi": "bunx --bun --no-install spectral lint openapi.yaml --ruleset ../../configs/openapi/api-style-rules.yaml",
    "start": "bun --smol dist/cli.js",
    "test": "bunx --no-install vitest run",
    "test:watch": "bunx --no-install vitest",
    "eval:recall": "bunx --no-install vitest run src/recall-v2/eval/index.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "4.1.5"
  }
}
