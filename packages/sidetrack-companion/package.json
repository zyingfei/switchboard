{
  "name": "@sidetrack/companion",
  "description": "Local Sidetrack companion process for loopback API and vault writes.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "sidetrack-companion": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:openapi": "spectral lint openapi.yaml --ruleset ../../configs/openapi/api-style-rules.yaml",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.5"
  }
}
