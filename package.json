{
  "name": "sidetrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "packages/*",
    "poc/dogfood-loop",
    "poc/local-bridge",
    "poc/local-bridge/companion",
    "poc/local-bridge/extension",
    "poc/mcp-server",
    "poc/obsidian-integration",
    "poc/provider-capture",
    "poc/recall-vector",
    "poc/vault-bridge/extension",
    "poc/vault-bridge/reader"
  ],
  "scripts": {
    "build": "bun run --sequential --filter './packages/*' build",
    "typecheck": "bun run --sequential --filter './packages/*' typecheck",
    "lint": "bun run --sequential --filter './packages/*' lint",
    "format:check": "bun run --sequential --filter './packages/*' format:check",
    "test": "bun run --sequential --filter './packages/*' test",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "verify:pocs": "bun run --sequential --filter './poc/**' --if-present compile && bun run --sequential --filter './poc/**' --if-present test && bun run --sequential --filter './poc/**' --if-present build"
  },
  "trustedDependencies": [
    "esbuild",
    "fsevents",
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "spawn-sync",
    "usearch"
  ]
}
