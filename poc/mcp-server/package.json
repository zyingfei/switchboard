{
  "name": "browser-ai-companion-mcp-server-poc",
  "description": "Standalone MCP server POC for Browser AI Companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "build": "bunx --bun --no-install tsup src/cli.ts src/smoke.ts --format esm --platform node --target node22 --out-dir dist --sourcemap",
    "compile": "bunx --bun --no-install tsc --noEmit",
    "start": "bun src/cli.ts",
    "smoke": "bun src/smoke.ts",
    "test": "bunx --no-install vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
