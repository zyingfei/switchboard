{
  "name": "bac-vault-bridge-extension-poc",
  "description": "PoC for Chrome MV3 File System Access writes into a local BAC vault bridge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bunx --bun --no-install wxt",
    "build": "bunx --bun --no-install wxt build",
    "compile": "bunx --bun --no-install tsc --noEmit",
    "test": "bunx --no-install vitest run",
    "test:unit": "bunx --no-install vitest run tests/unit",
    "postinstall": "bunx --bun --no-install wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "wxt": "^0.20.25"
  }
}
