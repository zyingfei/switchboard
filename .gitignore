# macOS
.DS_Store
._*

# Editor swap files
*.swp
*.swo

# Local environment
.env
.env.local
node_modules/

# Local-only T1 record/replay packs (also protects repo-relative
# SIDETRACK_TEST_SESSIONS_DIR overrides).
.sidetrack-test-sessions/
sidetrack-test-sessions/
test-sessions/

# Private working directory (kept on poc-planning only)
imports/
# Claude -> Codex worker local config and logs
.claude-codex-worker/

# Claude Code project state (worktrees, settings, agent dumps)
.claude/
.codex/

# JetBrains / IntelliJ workspace
.idea/

# Local dogfood / manual-test browser profiles and vaults.
# These directories contain real bridge keys, rendezvous secrets, replica
# keypairs, audit logs, recall indices, and workstream content — they MUST
# NOT be committed even when they live under packages/.
.sidetrack-browser-profiles/
packages/.sidetrack-browser-profiles/

# Local vault overrides (auto-generated runtime state)
.sidetrack-vault*/
sidetrack-vault*/

# Screen session logs
screenlog.*

# Build artifacts + diagnostics (auto-generated, never commit)
packages/*/.wxt/
.diag-heap/
*.log
error.log
